								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseURL}}/records?type=INCOME&userId={{userId}}&category=third category",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"records"
							],
							"query": [
								{
									"key": "type",
									"value": "INCOME"
								},
								{
									"key": "userId",
									"value": "{{userId}}"
								},
								{
									"key": "category",
									"value": "third category"
								}
							]
						},
						"description": "Admin and analyst only route. To get filtered records."
					},
					"response": []
