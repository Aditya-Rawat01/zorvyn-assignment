{
	"info": {
		"_postman_id": "47d9d13c-019b-4061-a2ce-44567571bda9",
		"name": "Zorvyn-Assignment",
		"description": "This collection demonstrates a finance backend with role-based access control.\n\nFlow:\n\n1. Login as admin (after seeding)\n    \n2. Create users\n    \n3. Create records\n    \n4. View dashboard analytics\n    \n\nRoles:\n\n- USER → dashboard only\n    \n- ANALYST → read-only records\n    \n- ADMIN → full access",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "33501405"
	},
	"item": [
		{
			"name": "user-routes",
			"item": [
				{
					"name": "create-user",
					"protocolProfileBehavior": {
						"disableBodyPruning": true
					},
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\":\"user@mail.com\",\n    \"password\": \"12345\",\n    \"role\": \"USER\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/users/login",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"users",
								"login"
							]
						},
						"description": "Only admins can create the new user.\n\nTo create the first every admin, use the command \"npm run seed\""
					},
					"response": []
				},
				{
					"name": "login-user",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\":\"admin@example.com\",\n    \"password\":\"admin123\"\n    // this is admin user login credentials, will work after the \"npm run seed\" command\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/users/login",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"users",
								"login"
							]
						},
						"description": "for logging in user and returning jwt token, which then needs to be set in the \"token\" variable."
					},
					"response": []
				},
				{
					"name": "update-user-role",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"role\": \"ANALYST\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/users/{{userId}}/role",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"users",
								"{{userId}}",
								"role"
							]
						},
						"description": "admin only route, to change the role of the user/analyst."
					},
					"response": []
				},
				{
					"name": "change-user-status (soft delete)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"isActive\": false\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/users/{{userId}}/status",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"users",
								"{{userId}}",
								"status"
							]
						},
						"description": "admin only route, to soft delete the user by changing the \"isActive\" status of the user."
					},
					"response": []
				},
				{
					"name": "delete-user",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseURL}}/users/{{userId}}",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"users",
								"{{userId}}"
							]
						},
						"description": "admin only route, to permanently delete the user."
					},
					"response": []
				}
			],
			"description": "contains all the user related routes, creation, updation (role, status), deletion (soft, hard)"
		},
